# --- Settings ---
units           metal
atom_style      atomic
dimension       3
boundary        p p p

# --- Create Atoms ---
lattice         fcc 4.05
region          box block 0 5 0 5 0 5
create_box      2 box
create_atoms    1 box
# Set 50% of the atoms to type 2 (Titanium) randomly
set             group all type/fraction 2 0.5 12345

# --- Define Potential ---
pair_style      meam
pair_coeff      * * library.meam Al Ti TiAl.meam Al Ti

# --- Output File (Force-based) ---
# fx fy fz: Forces acting on atoms.
# Acceleration = Force / Mass formula will be applied in Python.
dump            1 all custom 1 output.txt id type x y z fx fy fz

run             0